# TripOrg Environment Configuration Example

# DATABASE CONFIGURATION
DB_HOST=postgres
DB_PORT=5432
DB_NAME=triporg
DB_USERNAME=triporg
DB_PASSWORD=triporg

# BACKEND CONFIGURATION
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-characters
JWT_EXPIRATION=86400000

# CORS Configuration - must include frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost

# File upload directory
FILE_UPLOAD_DIR=/app/uploads

# MAIL CONFIGURATION
MAIL_HOST=mailpit
MAIL_PORT=1025

# FRONTEND CONFIGURATION
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080/api/v1

# N8N AI INTEGRATION
N8N_ENABLED=true
N8N_WEBHOOK_URL=http://triporg-n8n:5678/webhook/triporg-ai